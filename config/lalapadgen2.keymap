#include <input/processors.dtsi>
#include <dt-bindings/zmk/zip_dynamic_scale.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

#define DEFAULT_LAYER   0
#define SECONDARY_LAYER 1
#define TERTIARY_LAYER  2
#define SYSTEM_LAYER    3

&mt { quick-tap-ms = <200>; };

&lt { quick-tap-ms = <200>; };

/ {
    behaviors {
        zip_dyn_scale: zip_dyn_scale {
            compatible = "zmk,behavior-zip-dynamic-scale";
            #binding-cells = <2>;
        };

        zip_dyn_scale_set: zip_dyn_scale_set {
            compatible = "zmk,behavior-zip-dynamic-scale-set";
            #binding-cells = <2>;
        };

        mt2: mod_tap2 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <125>;
            bindings = <&kp>, <&kp>;
        };

        tap_dance_layer_1and2: tap_dance_layer_1and2 {
            compatible = "zmk,behavior-tap-dance";
            label = "td_mo12";
            #binding-cells = <0>;
            bindings = <&mo 1>, <&mo 2>;
        };
    };

    combos {
        compatible = "zmk,combos";

        CONBO_ESC {
            bindings = <&kp ESCAPE>;
            key-positions = <0 1>;
        };

        COMBO_TAB {
            bindings = <&kp TAB>;
            key-positions = <10 11>;
        };

        lang1 {
            bindings = <&kp LANGUAGE_1>;
            key-positions = <12 13>;
        };

        lang2 {
            bindings = <&kp LANGUAGE_2>;
            key-positions = <17 16>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        DEFAULT_LAYER {
            display-name = "Default";
            bindings = <
&mt2 LEFT_ALT Q      &kp W      &kp E         &kp R        &kp T                                 &kp Y            &kp U                &kp I        &kp O       &mt2 LEFT_ALT P
&mt2 LEFT_SHIFT A    &kp S      &kp D         &kp F        &kp G                                 &kp H            &kp J                &kp K        &kp L       &mt2 LEFT_SHIFT MINUS
&mt2 LEFT_CONTROL Z  &kp X      &kp C         &kp V        &kp B                                 &kp N            &kp M                &kp COMMA    &kp PERIOD  &mt2 LEFT_CONTROL SLASH
&kp LCTRL            &kp LWIN   &kp LEFT_ALT  &lt 2 SPACE  &mo 1      &kp LANG1  &kp LANGUAGE_2  &lt 1 BACKSPACE  &mt2 LEFT_SHIFT RET  &mo 3        &mo 3       &kp BACKSLASH
                     &none      &kp RIGHT     &kp DOWN     &kp LEFT   &kp UP     &kp UP          &kp LEFT         &kp DOWN             &kp RIGHT    &none
&mkp LCLK            &mkp RCLK  &mkp MCLK                                                                                              &mkp LCLK    &mkp RCLK   &mkp MCLK
&mkp MB4             &mkp MB5   &kp LG(TAB)   &kp LG(D)    &kp LCTRL                             &mkp MB4         &mkp MB5             &kp LG(TAB)  &kp LG(D)   &kp LCTRL
            >;
        };

        SECONDARY_LAYER {
            display-name = "secondary_layer";
            bindings = <
&kp PIPE          &kp BACKSLASH      &kp LEFT_BRACKET      &kp RIGHT_BRACKET      &kp DOUBLE_QUOTES                  &kp GRAVE         &kp N7             &kp N8        &kp N9        &kp EQUAL
&kp LEFT_SHIFT    &kp N7             &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp TILDE                          &kp COMMA         &kp NUMBER_4       &kp N5        &kp NUMBER_6  &trans
&kp EXCL          &kp QUESTION       &kp SEMICOLON         &kp COLON              &kp UNDER                          &kp PERIOD        &kp NUMBER_1       &kp NUMBER_2  &kp NUMBER_3  &trans
&trans            &trans             &trans                &trans                 &trans             &trans  &trans  &kp DEL           &kp N0             &trans        &trans        &trans
                  &trans             &trans                &trans                 &trans             &trans  &trans  &trans            &trans             &trans        &trans
&trans            &trans             &trans                                                                                                               &trans        &trans        &trans
&kp LC(LG(LEFT))  &kp LC(LG(RIGHT))  &trans                &trans                 &trans                             &kp LC(LG(LEFT))  &kp LC(LG(RIGHT))  &trans        &trans        &trans
            >;
        };

        TERTIARY_LAYER {
            display-name = "tertiary_layer";
            bindings = <
&kp F12              &kp F7  &kp F8  &kp F9  &kp LA(F4)                           &kp LS(LG(S))  &kp HOME                &kp UP_ARROW    &kp END          &trans
&mt2 LEFT_SHIFT F11  &kp F4  &kp F5  &kp F6  &kp LG(LEFT_ARROW)                   &trans         &kp LEFT                &kp DOWN_ARROW  &kp RIGHT        &trans
&kp F10              &kp F1  &kp F2  &kp F3  &kp LG(RIGHT_ARROW)                  &kp LG(TAB)    &kp LG(LC(LEFT_ARROW))  &trans          &kp LC(LG(TAB))  &trans
&trans               &trans  &trans  &trans  &trans               &trans  &trans  &kp DELETE     &trans                  &trans          &trans           &trans
                     &trans  &trans  &trans  &trans               &trans  &trans  &trans         &trans                  &trans          &trans
&trans               &trans  &trans                                                                                      &trans          &trans           &trans
&trans               &trans  &trans  &trans  &trans                               &trans         &trans                  &trans          &trans           &trans
            >;
        };

        SYSTEM_LAYER {
            display-name = "system_layer";
            bindings = <
&kp F1   &kp F2   &kp F3   &kp F4   &kp F5                   &out OUT_TOG                   &bt BT_SEL 0                   &bt BT_SEL 1                   &bt BT_SEL 2                   &bt BT_SEL 3
&kp F6   &kp F7   &kp F8   &kp F9   &kp F10                  &sys_reset                     &bootloader                    &bt BT_CLR                     &bt BT_CLR_ALL                 &trans
&kp F11  &kp F12  &kp F13  &kp F14  &kp F15                  &zip_dyn_scale ZDS_XY ZDS_INC  &zip_dyn_scale ZDS_XY ZDS_DEC  &zip_dyn_scale ZDS_SC ZDS_INC  &zip_dyn_scale ZDS_SC ZDS_DEC  &zip_dyn_scale ZDS_ALL ZDS_RST
&trans   &trans   &trans   &trans   &trans   &trans  &trans  &trans                         &trans                         &trans                         &trans                         &trans
         &trans   &trans   &trans   &trans   &trans  &trans  &trans                         &trans                         &trans                         &trans
&trans   &trans   &trans                                                                                                   &trans                         &trans                         &trans
&trans   &trans   &trans   &trans   &trans                   &trans                         &trans                         &trans                         &trans                         &trans
            >;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        Cond_Syslayer {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };
};
